    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const job = $('Loop Over Jobs').item.json;\nconst resumeText = $('Convert Resume Binary to Text').item.json.text || $('Convert Resume Binary to Text').item.json.data || '';\n\nconst promptText = `You are a careful resume-tailoring assistant. Adapt the candidate resume below to the job description.\\n\\nDo not invent experience, titles, or metrics that are not present in the source resume. Produce a finished, tailored resume in clear text format.\\n\\nJOB TITLE: ${job.title}\\nCOMPANY: ${job.company}\\n\\nJOB DESCRIPTION:\\n${job.description}\\n\\nMASTER RESUME:\\n${resumeText}\\n\\nTailor this resume for the job above.`;\n\nconst body = {\n  contents: [\n    {\n      parts: [\n        { text: promptText }\n      ]\n    }\n  ]\n};\n\nreturn { json: { body, jobTitle: job.title, company: job.company, jobUrl: job.job_url, jobId: job.job_id } };"
      },
