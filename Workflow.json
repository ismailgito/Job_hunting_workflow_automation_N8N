    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const resp = $json.body || $json;\nconst tailoredText = resp.candidates?.[0]?.content?.parts?.[0]?.text || '';\nconst prev = $('Build Gemini Request').item.json;\nconst rawUrl = prev.jobUrl || '';\nconst finalUrl = rawUrl.trim().startsWith('http') ? rawUrl.trim() : 'https://www.linkedin.com/jobs/';\nlet cleanId = prev.jobId || '';\nif (cleanId.includes('http') || cleanId.length > 35) {\n  cleanId = cleanId.split('?')[0].split('/').pop().substring(0, 30);\n}\nif (!cleanId) {\n  cleanId = Math.random().toString(36).substring(2, 12);\n}\nreturn { json: { tailoredResume: tailoredText, jobTitle: prev.jobTitle, company: prev.company, jobUrl: finalUrl, jobId: cleanId } };"
      },
