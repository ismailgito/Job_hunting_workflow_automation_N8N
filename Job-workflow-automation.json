      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [-1264, 704],
      "alwaysOutputData": true,
      "notesInFlow": true,
      "notes": "THIS NODE WORKED WELL NO WORRIES "
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all().map(i => i.json);\nconst seen = new Set();\nconst out = [];\nfor (const job of items) {\n  const key = (job.company + '|' + job.title).toLowerCase().trim();\n  if (!job.title || seen.has(key)) continue;\n  seen.add(key);\n  out.push({ json: job });\n}\nreturn out;"
      },
