      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst jobs = (resp.data && Array.isArray(resp.data.jobs)) ? resp.data.jobs : (Array.isArray(resp.data) ? resp.data : (resp.jobs || []));\n\nif (!Array.isArray(jobs) || jobs.length === 0) {\n  return [];\n}\n\nreturn jobs.map(job => ({\n  json: {\n    job_id: job.job_id || job.id || '',\n    title: job.job_title || job.title || '',\n    company: job.employer_name || job.company || '',\n    description: job.job_description || job.description || '',\n    job_url: job.job_apply_link || job.job_url || '',\n    source: 'jsearch'\n  }\n}));"
      },
